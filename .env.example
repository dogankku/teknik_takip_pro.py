# ── Teknik Takip Pro — Ortam Değişkenleri Şablonu ────────────────────────────
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ── Uygulama Portu ────────────────────────────────────────────────────────────
APP_PORT=8501

# ── E-posta (Bildirim & Şifre Sıfırlama) ─────────────────────────────────────
# SMTP sunucusu yapılandırması.
# Örnek (Gmail): SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sizin@email.com
SMTP_PASS=uygulama-sifresi

# ── Telegram Bot (İsteğe Bağlı) ───────────────────────────────────────────────
# Telegram bot token (BotFather'dan alınır)
# Bildirim ayarlarından chat_id girilmelidir.
TELEGRAM_BOT_TOKEN=

# ── Twilio WhatsApp (İsteğe Bağlı) ────────────────────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=whatsapp:+14155238886

# ── Google Sheets (İsteğe Bağlı) ─────────────────────────────────────────────
# SQLite varsayılan depolama motorudur.
# Google Sheets senkronizasyonu için:
# 1. GCP Service Account oluşturun
# 2. .streamlit/secrets.toml dosyasına credentials ekleyin
#    (bkz. README_FULL_PATCH.md)
